# Core Application
PROJECT_NAME=ScribeDesk Backend
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=false
PORT=8000
HOST=0.0.0.0

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:5173"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=TEXT

# Database
DATABASE_URL=

# Redis
REDIS_URL=rediss://
CELERY_BROKER_URL=rediss://
CELERY_RESULT_BACKEND=rediss://

# Auth
SESSION_EXPIRY_SECONDS=86400

# AI/LLM
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Fast LLM (Routing, Extraction, Nudges)
FAST_LLM_PROVIDER=groq
FAST_LLM_MODEL=openai/gpt-oss-120b
FAST_LLM_TEMP=0.2
FAST_LLM_FALLBACK_PROVIDER=google
FAST_LLM_FALLBACK_MODEL=gemini-3.1-flash-lite-preview

# Tiny LLM (Quick operations, structured output)
TINY_LLM_PROVIDER=groq
TINY_LLM_MODEL=openai/gpt-oss-20b
TINY_LLM_TEMP=0.2
TINY_LLM_FALLBACK_PROVIDER=google
TINY_LLM_FALLBACK_MODEL=gemini-3.1-flash-lite-preview

# Smart LLM (Clinical Reasoning, Synthesis)
SMART_LLM_PROVIDER=google
SMART_LLM_MODEL=gemini-2.5-flash-lite
SMART_LLM_TEMP=1.0
SMART_LLM_FALLBACK_PROVIDER=google
SMART_LLM_FALLBACK_MODEL=gemini-3-flash-preview

# External APIs
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3-medical
DEEPGRAM_CHUNK_SIZE=5
SCRIBE_IDLE_TIMEOUT_SECONDS=60
BRAVE_SEARCH_API_KEY=

# S3 Storage
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PLAN_ID=

# Payment (shared for Stripe & Razorpay)
PAYMENT_SUCCESS_URL=http://localhost:8000/docs
PAYMENT_CANCEL_URL=http://localhost:8000/redoc

# Limits
FREE_TRIAL_DAYS=14
FREE_SCRIBE_LIMIT_MINUTES=400
TRIAL_SCRIBE_LIMIT_MINUTES=800
PRO_SCRIBE_LIMIT_MINUTES=3600
